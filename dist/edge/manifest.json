{
  "version": "1.0.0",
  "name": "pracc-optimizer",
  "description": "Optimize your pracc scrim search with custom utils.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "64": "icons/128.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage"
  ],
  "options_page": "options/index.html",
  "content_scripts": [
    {
      "matches": [
        "https://pracc.com/team/*"
      ],
      "js": [
        "content_scripts/content-0.js"
      ],
      "css": [
        "content_scripts/content-0.css"
      ]
    }
  ],
  "author": "LeonTM",
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "64": "icons/128.png",
      "128": "icons/128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content_scripts/content-0.css",
        "content_scripts/styles.c7bd1cb9.css"
      ],
      "matches": [
        "https://pracc.com/*"
      ]
    }
  ]
}