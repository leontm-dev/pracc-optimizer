{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 2,
  "manifest_version": 3,
  "version": "1.0.0",
  "name": "Pracc-Optimizer",
  "description": "Content script example rendered with React. Mounts a small UI inside a Shadow DOM on any page.",
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "64": "images/icon.png",
    "128": "images/icon.png"
  },
  "homepage_url": "https://github.com/leontm-dev/pracc-optimizer/wiki",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["./content/scripts.tsx"]
    }
  ],
  "permissions": ["sidePanel"],
  "version_name": "1.0 beta",
  "chromium:side_panel": {
    "default_path": "sidebar/index.html",
    "default_title": "Extension.js Shadcn Sidebar Panel"
  },
  "firefox:sidebar_action": {
    "default_panel": "sidebar/index.html",
    "default_title": "Extension.js Shadcn Sidebar Panel"
  },
  "chromium:permissions": ["sidePanel"]
}
